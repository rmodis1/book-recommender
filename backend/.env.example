# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Supabase (https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Books API (https://console.cloud.google.com/apis/library/books.googleapis.com)
GOOGLE_BOOKS_API_KEY=

# NYT Books API (https://developer.nytimes.com/apis)
NYT_API_KEY=

# Tavily MCP web search (https://tavily.com) — optional, Web Curator disabled if blank
TAVILY_API_KEY=

# CORS — comma-separated list of allowed origins
# Production: set to your Vercel URL, e.g. https://shelf-abc123.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Set to "production" in Railway to disable /docs and /redoc
ENVIRONMENT=development
